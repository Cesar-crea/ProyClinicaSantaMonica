@model ProyectoSantaMonica_Cesar.Models.ComprobanteDePago

@{
    ViewData["Title"] = "Registrar Comprobante de Pago";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
        color: #333;
    }

    .header-bar {
        background-color: #007bff;
        color: white;
        min-height: 70px;
        border-radius: 12px;
        padding: 15px 25px;
        display: flex;
        align-items: center;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

        .header-bar h2 {
            font-weight: 600;
            font-size: 1.3rem;
            margin: 0;
        }

    .card-form {
        background-color: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

        .card-form label {
            font-weight: 500;
            font-size: 0.9rem;
        }

        .card-form input,
        .card-form select {
            font-size: 0.9rem;
            height: calc(1.8em + 0.75rem + 2px);
        }

    .btn-success {
        background-color: #28c76f;
        border: none;
        font-weight: 600;
    }

        .btn-success:hover {
            background-color: #22b365;
        }

    .btn-buscar-cita {
        background-color: #17a2b8;
        color: white;
        font-weight: 600;
    }

        .btn-buscar-cita:hover {
            background-color: #138496;
        }
</style>

<div class="container mt-4">

    <!-- Encabezado -->
    <div class="header-bar">
        <h2><i class="bi bi-file-earmark-text me-2"></i>Registrar Comprobante de Pago</h2>
    </div>

    <!-- Formulario -->
    <div class="card-form">
        <form asp-action="Registrar" method="post">

            <!-- CITA -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Cita</label>
                    <div class="input-group">
                        <input type="hidden" asp-for="Id_Cita" id="idCita" />
                        <input type="text" class="form-control" id="citaSeleccionada" readonly placeholder="Seleccione una cita">
                        <button type="button" class="btn btn-buscar-cita" data-bs-toggle="modal" data-bs-target="#buscarCitaModal">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-6">
                    <label>Paciente</label>
                    <input type="text" class="form-control" id="pacienteInfo" readonly>
                </div>
            </div>

            <!-- INFO -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Motivo</label>
                    <input type="text" class="form-control" id="motivoInfo" readonly>
                </div>

                <div class="col-md-6">
                    <label>Fecha</label>
                    <input type="text" class="form-control" id="fechaInfo" readonly>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Hora</label>
                    <input type="text" class="form-control" id="horaInfo" readonly>
                </div>

                <div class="col-md-6">
                    <label>Médico</label>
                    <input type="text" class="form-control" id="medicoInfo" readonly>
                </div>
            </div>

            <!-- DATOS -->
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Método de Pago</label>
                    <select asp-for="Metodo_Pago" class="form-select" required>
                        <option value="">Seleccione...</option>
                        <option>EFECTIVO</option>
                        <option>TARJETA</option>
                        <option>TRANSFERENCIA</option>
                    </select>
                </div>

                <div class="col-md-6">
                    <label>Nombre Pagador</label>
                    <input asp-for="Nombre_Pagador" class="form-control" required />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Apellidos</label>
                    <input asp-for="Apellidos_Pagador" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label>DNI</label>
                    <input asp-for="Dni_Pagador" class="form-control" pattern="\d{8}" required />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label>Contacto</label>
                    <input asp-for="Contacto_Pagador" class="form-control" required />
                </div>

                <div class="col-md-6">
                    <label>Monto</label>
                    <input asp-for="Monto" class="form-control" type="number" step="0.01" required />
                </div>
            </div>

            <!-- BOTONES -->
            <div class="d-flex justify-content-between mt-3">
                <a asp-action="Listar" class="btn btn-secondary" style="width:49%;">Cancelar</a>
                <button type="submit" class="btn btn-success" style="width:49%;">Guardar</button>
            </div>

        </form>
    </div>

</div>

@await Html.PartialAsync("_ModalSeleccionarCita")

<!-- SCRIPTS -->
@section Scripts {
    <script>
               function seleccionarCita(id, paciente, fecha, hora, medico, motivo) {

            document.getElementById("idCita").value = id;
            document.getElementById("citaSeleccionada").value = "Cita #" + id;

            document.getElementById("pacienteInfo").value = paciente;
            document.getElementById("fechaInfo").value = fecha;
            document.getElementById("horaInfo").value = hora;
            document.getElementById("medicoInfo").value = medico;
            document.getElementById("motivoInfo").value = motivo;

                    // 🔥 cerrar modal AQUÍ (faltaba esto)
        const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('buscarCitaModal'));
        modal.hide();
        }
    </script>

    <script src="~/js/cdp.js"></script>
}