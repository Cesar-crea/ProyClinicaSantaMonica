@{
    Layout = null;
}
<!DOCTYPE html>
<html  lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clínica Santa Mónica - Iniciar Sesión</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Íconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Fuente -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #eaf2ff, #f5f8fc);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
        }

            /* Animación fondo */
            body::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: #007bff33;
                border-radius: 50%;
                top: -100px;
                left: -100px;
                filter: blur(100px);
            }

            body::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                background: #00c6ff33;
                border-radius: 50%;
                bottom: -100px;
                right: -100px;
                filter: blur(100px);
            }

        .login-container {
            position: relative;
            z-index: 2;
            background-color: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
            width: 400px;
            padding: 40px 35px;
            text-align: center;
            opacity: 0;
            transform: translateY(30px) scale(0.95);
            transition: all 0.7s ease;
        }

            .login-container.show {
                opacity: 1;
                transform: translateY(0) scale(1);
            }

        .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            gap: 10px;
        }

            .logo i {
                font-size: 2.2rem;
                color: #007bff;
                transition: transform 0.3s;
            }

            .logo:hover i {
                transform: scale(1.1);
            }

        .logo-text {
            font-size: 1.6rem;
            font-weight: 600;
            color: #007bff;
            line-height: 1.2;
        }

        .login-title {
            font-size: 1.4rem;
            font-weight: 600;
            color: #222;
            margin-bottom: 25px;
        }

        .input-group {
            background-color: #f1f3f5;
            border-radius: 12px;
            padding: 5px 10px;
            margin-bottom: 18px;
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

            .input-group:focus-within {
                border: 1px solid #007bff;
                background-color: #ffffff;
                box-shadow: 0 0 0 0.2rem rgba(0,123,255,.15);
            }

            .input-group i {
                color: #007bff;
                font-size: 1.2rem;
                margin-top: 6px;
            }

        .form-control {
            background: transparent;
            border: none;
            box-shadow: none;
            font-size: 0.95rem;
        }

            .form-control:focus {
                outline: none;
                background: transparent;
            }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #007bff, #0056b3);
            color: white;
            font-weight: 600;
            border-radius: 12px;
            padding: 10px 0;
            margin-top: 10px;
            transition: all 0.3s ease;
            border: none;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,123,255,0.3);
            }

        .small-link {
            font-size: 0.9rem;
            color: #007bff;
            text-decoration: none;
            transition: 0.2s;
        }

            .small-link:hover {
                text-decoration: underline;
                color: #0056b3;
            }

        .alert {
            border-radius: 10px;
            font-size: 0.9rem;
        }

        @@media (max-width: 480px) {
            .login-container

        {
            width: 90%;
            padding: 30px 25px;
        }

        }
    </style>
</head>

<body>

    <div class="login-container" id="loginBox">

        <div class="logo">
            <i class="bi bi-heart-pulse"></i>
            <div class="logo-text">Clínica<br>Santa Mónica</div>
        </div>

        <h4 class="login-title">Iniciar Sesión</h4>

        <form asp-controller="Usuario" asp-action="Login" method="post">

            @Html.AntiForgeryToken()

            <div class="input-group">
                <span class="input-group-text bg-transparent border-0">
                    <i class="bi bi-person"></i>
                </span>
                <input type="text" class="form-control" name="username" placeholder="Usuario" required autofocus>
            </div>

            <div class="input-group">
                <span class="input-group-text bg-transparent border-0">
                    <i class="bi bi-lock"></i>
                </span>
                <input type="password" class="form-control" name="password" placeholder="Contraseña" required>
            </div>

            <div class="d-flex justify-content-end mb-3">
                <a href="#" class="small-link">Cambiar contraseña</a>
            </div>

            <button type="submit" class="btn btn-login">Iniciar sesión</button>

        </form>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Error
            </div>
        }

        @if (ViewBag.Logout != null)
        {
            <div class="alert alert-info mt-3">
                @ViewBag.Logout
            </div>
        }

    </div>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Animación entrada -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
          document.getElementById("loginBox").classList.add("show");
        });
    </script>

</body>
</html>