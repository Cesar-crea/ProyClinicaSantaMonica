@model ProyectoSantaMonica_Cesar.Models.Especialidad

@{
    ViewData["Title"] = "Registrar Especialidad";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
        color: #333;
    }

    .card-form {
        background-color: #fff;
        border-radius: 16px;
        padding: 35px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

        .card-form label {
            font-weight: 500;
            font-size: 0.95rem;
        }

    .card-header-custom {
        background-color: #28c76f;
        color: white;
        font-weight: 600;
        font-size: 1.3rem;
        border-radius: 16px;
        padding: 20px 25px;
        margin-bottom: 15px;
        text-align: center;
    }

    .btn-success {
        background-color: #28c76f;
        border: none;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .btn-success:hover {
            background-color: #22b365;
        }

    .btn-secondary {
        background-color: #6c757d;
        border: none;
        font-weight: 600;
    }

    .btn-container {
        display: flex;
        gap: 10px;
    }

    input.form-control {
        height: 50px;
    }
</style>

<div class="container mt-5 d-flex justify-content-center">
    <div class="card-form" style="width: 80%;">

        <div class="card-header-custom">
            Registrar Especialidad
        </div>

     

        <form asp-action="Registrar" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-4">
                <label>Nombre de Especialidad:</label>
                <input asp-for="Nombre" class="form-control"
                       id="nombreEspecialidad"
                       required
                       pattern="^[A-Za-zÁÉÍÓÚáéíóúÑñ]+(\s?[A-Za-zÁÉÍÓÚáéíóúÑñ]+)*$" />
                <span id="mensajeNombre" class="text-danger"></span>

            </div>

            <div class="btn-container">
                <button type="submit" class="btn btn-success w-100">
                    <i class="bi bi-save"></i> Guardar
                </button>

                <a asp-action="Index" class="btn btn-secondary w-100">
                    <i class="bi bi-arrow-left-circle"></i> Volver
                </a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            $("#nombreEspecialidad").on("keyup", function () {

                let nombre = $(this).val();
                let id = $("#Id_Especialidad").length ? $("#Id_Especialidad").val() : 0;

                if (nombre.length < 3) {
                    $("#mensajeNombre").text("");
                    $("button[type='submit']").prop("disabled", false);
                    return;
                }

                $.get("/Especialidad/ExisteNombre", { nombre: nombre, id: id }, function (data) {

                    if (data.existe) {
                        $("#mensajeNombre").text("⚠ Ya existe esta especialidad");
                        $("#mensajeNombre").css("color", "red");
                        $("button[type='submit']").prop("disabled", true);
                    } else {
                        $("#mensajeNombre").text("✔ Disponible");
                        $("#mensajeNombre").css("color", "green");
                        $("button[type='submit']").prop("disabled", false);
                    }

                });

            });

        });
    </script>
}




