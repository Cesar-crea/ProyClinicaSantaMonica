@model List<ProyectoSantaMonica_Cesar.Models.Especialidad>

@{
    ViewData["Title"] = "Listado de Especialidades";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        max-width: 800px;
        margin: 50px auto;
    }

    .card-header {
        background: #007bff;
        color: white;
        padding: 20px;
        border-radius: 16px 16px 0 0;
    }

    .table thead {
        background: #eaf2ff;
        color: #0056b3;
    }
</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-list-check"></i> Listado de Especialidades</h4>
        </div>

        <div class="card-body">
            <div class="text-end mb-3">
                <a asp-action="Registrar" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Nueva Especialidad
                </a>
            </div>

            <table class="table table-bordered text-center">
                <thead>
                    <tr>
                        <th>Nombre de Especialidad</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>@e.Nombre</td>
                            <td>
                                <a asp-action="Editar" asp-route-id="@e.Id_Especialidad" class="btn btn-primary btn-sm">
                                    Editar
                                </a>

                                <button class="btn btn-danger btn-sm"
                                        onclick="confirmarEliminacion(@e.Id_Especialidad)">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



<script>
    function confirmarEliminacion(id) {
        Swal.fire({
            title: '¿Está seguro?',
            text: 'Se eliminará definitivamente',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Especialidad/Eliminar/' + id;
            }
        });
    }

    // Mensajes
    var mensaje = '@TempData["success"]';
    var error = '@TempData["error"]';

    if (mensaje)
        Swal.fire('Éxito', mensaje, 'success');

    if (error)
        Swal.fire('Error', error, 'error');


        //validacin del nombre al escribir

     
</script>