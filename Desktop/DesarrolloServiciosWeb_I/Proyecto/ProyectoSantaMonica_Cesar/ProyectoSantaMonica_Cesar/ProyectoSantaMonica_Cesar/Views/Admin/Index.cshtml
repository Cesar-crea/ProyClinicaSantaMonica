@model ProyectoSantaMonica_Cesar.Models.Usuario

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Administrador</title>

    <!-- Bootstrap e íconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #ffffff;
            font-family: 'Poppins', sans-serif;
            color: #2c3e50;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem;
            text-align: center;
        }

        .logo-container img {
            width: 160px;
            margin-bottom: 1.5rem;
        }

        .profile-section {
            text-align: center;
            margin-bottom: 1.5rem;
        }

            .profile-section img {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                border: 3px solid #007bff;
                object-fit: cover;
                margin-bottom: 0.8rem;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            }

        .logout-btn {
            border: none;
            border-radius: 20px;
            padding: 0.45rem 1.1rem;
            background-color: #007bff;
            color: white;
            font-weight: 500;
            transition: background-color 0.2s ease-in-out;
        }

            .logout-btn:hover {
                background-color: #0066d1;
            }

        .welcome h2 {
            color: #004a99;
            font-weight: 600;
            margin-bottom: 0.4rem;
        }

        .welcome p {
            color: #4f5f78;
            margin-bottom: 0.4rem;
        }

        .friendly-msg {
            color: #007bff;
            font-size: 1rem;
            font-weight: 500;
            margin-top: 0.8rem;
        }

        .options {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-top: 2rem;
            width: 100%;
            max-width: 1200px;
        }

        @@media (max-width: 992px) {
            .options {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 576px) {
            .options {
                grid-template-columns: 1fr;
            }
        }

        .card-option {
            background-color: white;
            border-radius: 12px;
            padding: 1.8rem;
            text-align: center;
            border: 1px solid #e5ecf6;
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s ease;
        }

            .card-option:hover {
                transform: translateY(-3px);
            }

            .card-option i {
                font-size: 2.2rem;
                color: #007bff;
                margin-bottom: 0.8rem;
            }

            .card-option h4 {
                color: #004a99;
                margin-bottom: 0.6rem;
                font-weight: 600;
            }

            .card-option p {
                color: #6c757d;
                font-size: 0.95rem;
                margin-bottom: 1rem;
            }

        .option-btn {
            border-radius: 20px;
            padding: 0.45rem 1.1rem;
            background-color: #007bff;
            color: white;
            border: none;
            font-weight: 500;
            transition: background-color 0.2s ease;
        }

            .option-btn:hover {
                background-color: #0066d1;
            }

            .option-btn i {
                color: #dfe9ff;
            }

        footer {
            text-align: center;
            font-size: 0.85rem;
            color: #6c757d;
            padding: 1rem 0;
            border-top: 1px solid #e3e9f0;
            background-color: #f9fbff;
        }
    </style>
</head>

<body>

    <div class="main-container">

        <!-- Logo -->
        <div class="logo-container">
            <img src="~/images/ClinicaStaMonicaLogoP.png" alt="Logo Clínica Santa Mónica">
       
        </div>

        <!-- Perfil -->
        <div class="profile-section">
          
            @if (Model != null)
            {
                <img src="@(Model.Img_Perfil ?? "/images/default-user.jpg")" alt="Foto de perfil" />
            }
            <form asp-controller="Usuario" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">
                    <i class="bi bi-box-arrow-right me-1"></i> Cerrar sesión
                </button>
            </form>
        </div>

        <!-- Bienvenida -->
        <div class="welcome">
            <h2>¡Hola, @Model.Nombres!</h2>
            <p>Cargo: @Model.Rol</p>
            <p class="friendly-msg">¿Qué deseas hacer hoy?</p>
        </div>

        <!-- Opciones -->
        <div class="options">

            <div class="card-option">
                <i class="bi bi-person-lines-fill"></i>
                <h4>Gestionar Usuarios</h4>
                <p>Administra las cuentas y permisos de los usuarios del sistema.</p>
                <a asp-controller="Admin" asp-action="Registro" class="btn option-btn">
                    <i class="bi bi-arrow-right-circle"></i> Ingresar
                </a>
            </div>

            <div class="card-option">
                <i class="bi bi-person-badge-fill"></i>
                <h4>Gestionar Médicos</h4>
                <p>Registra, edita y administra la información de los médicos.</p>
                <a asp-controller="Medico" asp-action="Index" class="btn option-btn">
                    <i class="bi bi-arrow-right-circle"></i> Ingresar
                </a>
            </div>

            <div class="card-option">
                <i class="bi bi-clock-history"></i>
                <h4>Gestionar Horarios</h4>
                <p>Configura los horarios de atención médica y disponibilidad.</p>
                <a asp-controller="Horario" asp-action="GestionarHorarios" class="btn option-btn">
                    <i class="bi bi-arrow-right-circle"></i> Ingresar
                </a>
            </div>

            <div class="card-option">
                <i class="bi bi-hospital-fill"></i>
                <h4>Gestionar Especialidades</h4>
                <p>Administra las áreas médicas y especialidades de la clínica.</p>
                <a asp-controller="Especialidad" asp-action="Listar" class="btn option-btn">
                    <i class="bi bi-arrow-right-circle"></i> Ingresar
                </a>
            </div>

        </div>
    </div>

    <footer>
        © 2026 Clínica Santa Mónica — Sistema de Gestión Hospitalaria
    </footer>

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var mensaje = '@TempData["mensaje"]';
        var error = '@TempData["error"]';

        if (mensaje && mensaje !== '') {
            Swal.fire({
                icon: 'success',
                title: '¡Éxito!',
                text: mensaje,
                confirmButtonColor: '#007bff'
            });
        } else if (error && error !== '') {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: error,
                confirmButtonColor: '#FF4C4C'
            });
        }
    </script>

</body>
</html>