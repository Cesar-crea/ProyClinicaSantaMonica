@model ProyectoSantaMonica_Cesar.Models.Cita

@{
    ViewData["Title"] = "Registrar Cita";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Registrar Cita</title>

    <!-- Bootstrap e íconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #f4f7fb;
            font-family: 'Poppins', sans-serif;
            color: #333;
        }

        .header-bar {
            background-color: #007bff;
            color: white;
            min-height: 70px;
            border-radius: 12px;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

            .header-bar h2 {
                font-weight: 600;
                font-size: 1.3rem;
                margin: 0;
                display: flex;
                align-items: center;
            }

        .card-form {
            background-color: #fff;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

            .card-form label {
                font-weight: 500;
                font-size: 0.9rem;
            }

            .card-form input.form-control,
            .card-form select.form-select,
            .card-form textarea.form-control {
                font-size: 0.9rem;
            }

        .btn-success {
            background-color: #28c76f;
            border: none;
            font-weight: 600;
        }

            .btn-success:hover {
                background-color: #22b365;
            }

        .btn-info {
            background-color: #17a2b8;
            color: white;
            font-weight: 600;
        }

            .btn-info:hover {
                background-color: #138496;
            }

        .btn-ver-horarios {
            background-color: #6c757d;
            color: white;
            font-weight: 600;
        }

        .btn-nuevo-paciente {
            background-color: white;
            color: #007bff;
            border: 2px solid #007bff;
            font-weight: 600;
        }

            .btn-nuevo-paciente:hover {
                background-color: #007bff;
                color: white;
            }

        .modal-dialog {
            max-width: 800px;
        }

        .modal-header {
            background-color: #007bff;
            color: white;
        }
    </style>
</head>

<body>

    <div class="container mt-4">

        <!-- HEADER -->
        <div class="header-bar">
            <h4><i class="bi bi-calendar-plus"></i> Registrar Nueva Cita</h4>
        </div>

  
        <!-- FORM -->
        <div class="card-form">
            <form asp-action="Registrar" method="post">

                <!-- PACIENTE -->
                <div class="mb-3">
                    <label>Paciente</label>
                    <div class="input-group">
                        <input type="text" id="pacienteNombre" class="form-control" readonly placeholder="Selecciona un paciente">
                        <input type="hidden" asp-for="Id_Paciente" id="pacienteId" />
                        <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#modalPacientes">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                <!-- MEDICO -->
                <div class="mb-3">
                    <label>Médico</label>
                    <div class="input-group">
                        <input type="text" id="medicoNombre" class="form-control" readonly placeholder="Selecciona un médico">
                        <input type="hidden" asp-for="Id_Medico" id="medicoId" />
                        <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#modalMedicos">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                <!-- FECHA Y HORA -->
                <div class="row mb-3">

                    <!-- FECHA -->
                    <div class="col-md-6">
                        <label>Fecha</label>
                        <input type="date" asp-for="Fecha" id="Fecha" class="form-control" />
                    </div>

                    <!-- HORA -->
                    <div class="col-md-6">
                        <label>Hora</label>
                        <div class="d-flex-hora">
                            @{
                                var horaActual = Model?.Hora.ToString(@"hh\:mm");
                            }

                            <select asp-for="Hora" class="form-select">
                                <option value="">Seleccionar</option>

                                @for (int h = 8; h <= 22; h++)
                                {
                                    var hora = $"{h:D2}:00";
                                    <option value="@hora" 
                                            selected="@(horaActual == hora)">
                                        @hora
                                    </option>
                                }
                            </select>

                            <button type="button" class="btn btn-info"
                                    onclick="mostrarHorarios(document.getElementById('medicoId').value||0)">
                                Ver horarios
                            </button>

                        </div>
                    </div>

                </div>

                <!-- VER HORARIOS -->
                <div class="mb-3 text-end">
                    <button type="button" class="btn btn-ver-horarios" onclick="mostrarHorarios(document.getElementById('medicoId').value)">
                        <i class="bi bi-eye"></i> Ver horarios ocupados
                    </button>
                </div>

                <!-- CONTENEDOR MODAL -->
                <div id="modalHorariosContainer"></div>

                <!-- MOTIVO -->
                <div class="mb-3">
                    <label>Motivo</label>
                    <textarea name="Motivo" class="form-control" rows="3"></textarea>
                </div>

                <!-- BOTONES -->
                <div class="d-flex justify-content-between">
                    <a asp-action="Listar" class="btn btn-secondary w-50 me-1">Cancelar</a>
                    <button type="submit" class="btn btn-success w-50 ms-1">Registrar</button>
                </div>

            </form>
        </div>

    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/citas.js"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire("Éxito", "@TempData["Success"]", "success");
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire("Error", "@TempData["Error"]", "error");
        </script>
    }

	<partial name="_ModalSeleccionarMedico" model="ViewBag.Medicos" />
	<partial name="_ModalSeleccionarPaciente" model="ViewBag.Pacientes" />
	

</body>
</html>
