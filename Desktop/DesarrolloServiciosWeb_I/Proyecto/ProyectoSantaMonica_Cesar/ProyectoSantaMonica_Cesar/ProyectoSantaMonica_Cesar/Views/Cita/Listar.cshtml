@model List<ProyectoSantaMonica_Cesar.Models.Cita>
@using ProyectoSantaMonica_Cesar.Models.enums

@{
    ViewData["Title"] = "Listado de Citas";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-4">

    <div class="card shadow-sm rounded-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-calendar-check"></i> Listado de Citas</h5>
        </div>

        <div class="card-body">

            <!-- BOTONES -->
            <div class="d-flex justify-content-between mb-3">
                <a asp-action="Registrar" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Registrar
                </a>

             
            </div>

            <!-- BUSQUEDA -->
            <form asp-action="Listar" method="get" class="mb-3">
                <div class="input-group">
                    <input type="text" name="texto" class="form-control"
                           value="@ViewBag.Texto"
                           placeholder="Buscar paciente..." />
                    <button class="btn btn-primary">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <!-- TABLA -->
            <div class="table-responsive">
                <table class="table table-hover table-bordered text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Paciente</th>
                            <th>Médico</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Motivo</th>
                            <th>Estado</th>
                            <th style="width:180px;">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var cita in Model)
                            {
                                <tr>
                                    <td>
                                        @(cita.Paciente != null
                                            ? $"{cita.Paciente.Nombres} {cita.Paciente.Apellidos}"
                                            : "Sin datos")
                                    </td>

                                    <td>
                                        @(cita.Medico != null
                                            ? $"{cita.Medico.Nombres} {cita.Medico.Apellidos}"
                                            : "Sin datos")
                                    </td>

                                    <td>@cita.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@cita.Hora.ToString(@"hh\:mm")</td>
                                    <td>@(string.IsNullOrEmpty(cita.Motivo) ? "-" : cita.Motivo)</td>

                                    <td>
                                        @{
                                            string badge = cita.Estado switch
                                            {
                                                EstadoCita.PAGADO => "bg-success",
                                                EstadoCita.PENDIENTE => "bg-warning text-dark",
                                                EstadoCita.CANCELADO => "bg-danger",
                                                EstadoCita.VENCIDO => "bg-secondary",
                                                EstadoCita.ATENDIDO => "bg-info",
                                                _ => "bg-dark"
                                            };
                                        }
                                        <span class="badge @badge">@cita.Estado</span>
                                    </td>

                                    <td>
                                        <a asp-action="Detalle" asp-route-id="@cita.Id_Cita"
                                           class="btn btn-warning btn-sm">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (cita.Estado == EstadoCita.PENDIENTE || cita.Estado == EstadoCita.PAGADO)
                                        {
                                            <a asp-action="Editar" asp-route-id="@cita.Id_Cita"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled>
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        }

                                        @if (cita.Estado == EstadoCita.PENDIENTE)
                                        {
                                            <button onclick="confirmarCancelar(@cita.Id_Cita)"
                                                    class="btn btn-danger btn-sm">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" disabled>
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-muted">
                                    No hay citas registradas
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmarCancelar(id) {
        Swal.fire({
            title: "¿Cancelar cita?",
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Sí, cancelar"
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/Cita/Cancelar/' + id;
            }
        });
    }

    let success = '@TempData["Success"]';
    let error = '@TempData["Error"]';

    if (success) Swal.fire("Éxito", success, "success");
    if (error) Swal.fire("Error", error, "error");
</script>