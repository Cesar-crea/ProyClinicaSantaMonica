@model ProyectoSantaMonica_Cesar.Models.Cita


@{
    ViewData["Title"] = "Detalle de Cita";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Detalle de Cita</title>

    <!-- Bootstrap e íconos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #f4f7fb;
            color: #333;
        }

        .header-bar {
            background-color: #fcd34d;
            color: #333;
            min-height: 70px;
            border-radius: 12px;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

            .header-bar h2 {
                font-weight: 600;
                font-size: 1.3rem;
                margin: 0;
            }

        .card-detail {
            background-color: #fff;
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
            margin-bottom: 30px;
        }

            .card-detail p {
                font-size: 0.95rem;
                margin-bottom: 0.8rem;
            }

        .badge-custom {
            padding: 0.45em 0.75em;
            font-size: 0.85rem;
        }

        .btn-back {
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container mt-4">

        <!-- Encabezado -->
        <div class="header-bar">
            <h2><i class="bi bi-info-circle me-2"></i>Detalle de Cita</h2>
        </div>

        <!-- Detalle -->
        <div class="card-detail">

            <p>
                <strong>Paciente:</strong>
                @(Model.Paciente?.Nombres + " " + Model.Paciente?.Apellidos)
            </p>

            <p>
                <strong>DNI:</strong>
                @Model.Paciente?.Dni
            </p>

            <p>
                <strong>Fecha:</strong>
                @Model.Fecha.ToString("dd/MM/yyyy")
            </p>

            <p>
                <strong>Hora:</strong>
                @Model.Hora.ToString(@"hh\:mm")
            </p>

            <p>
                <strong>Médico:</strong>
                @(Model.Medico?.Nombres + " " + Model.Medico?.Apellidos)
            </p>

            <p>
                <strong>Especialidad:</strong>
                @(Model.Medico?.Especialidad ?? "N/A")
            </p>

            <p>
                <strong>Motivo:</strong>
                @Model.Motivo
            </p>

            <p>
                <strong>Estado:</strong>
                @{
                    var clase = Model.Estado.ToString() == "PAGADO"
                    ? "badge bg-success badge-custom"
                    : Model.Estado.ToString() == "PENDIENTE"
                    ? "badge bg-warning text-dark badge-custom"
                    : "badge bg-secondary badge-custom";
                }
                <span class="@clase">@Model.Estado</span>
            </p>

            <p>
                <strong>Registrado por:</strong>
                @(Model.Usuario?.Nombres + " " + Model.Usuario?.Apellidos)
            </p>

        </div>

        <!-- Botón volver -->
        <div class="mt-3 text-center">
            <a asp-action="Listar" class="btn btn-secondary btn-back px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
            </a>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
