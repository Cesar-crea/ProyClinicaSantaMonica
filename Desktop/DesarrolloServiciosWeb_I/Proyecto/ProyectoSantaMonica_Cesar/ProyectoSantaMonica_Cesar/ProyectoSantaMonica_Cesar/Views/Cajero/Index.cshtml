@model ProyectoSantaMonica_Cesar.Models.Usuario

@{
    ViewData["Title"] = "Panel Cajero";
}

@section Styles {
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            background-color: #ffffff;
            font-family: 'Poppins', sans-serif;
            color: #2c3e50;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem;
            text-align: center;
        }

        .logo-container img {
            width: 160px;
            margin-bottom: 1.5rem;
        }

        .profile-section {
            text-align: center;
            margin-bottom: 1.5rem;
        }

            .profile-section img {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                border: 3px solid #007bff;
                object-fit: cover;
                margin-bottom: 0.8rem;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            }

        .logout-btn {
            border: none;
            border-radius: 20px;
            padding: 0.45rem 1.1rem;
            background-color: #007bff;
            color: white;
            font-weight: 500;
            transition: background-color 0.2s ease-in-out;
        }

            .logout-btn:hover {
                background-color: #0066d1;
            }

        .welcome h2 {
            color: #004a99;
            font-weight: 600;
            margin-bottom: 0.4rem;
        }

        .welcome p {
            color: #4f5f78;
            margin-bottom: 0.4rem;
        }

        .friendly-msg {
            color: #007bff;
            font-size: 1rem;
            font-weight: 500;
            margin-top: 0.8rem;
        }

        .options {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 2rem;
            width: 100%;
        }

        .card-option {
            background-color: white;
            border-radius: 12px;
            padding: 2rem;
            width: 380px;
            text-align: center;
            border: 1px solid #e5ecf6;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s ease;
        }

            .card-option:hover {
                transform: translateY(-3px);
            }

            .card-option i {
                font-size: 2.5rem;
                color: #007bff;
                margin-bottom: 1rem;
            }

            .card-option h4 {
                color: #004a99;
                margin-bottom: 0.6rem;
                font-weight: 600;
            }

            .card-option p {
                color: #6c757d;
                font-size: 0.95rem;
                margin-bottom: 1rem;
            }

        .option-btn {
            border-radius: 20px;
            padding: 0.45rem 1.1rem;
            background-color: #007bff;
            color: white;
            border: none;
            font-weight: 500;
            transition: background-color 0.2s ease;
        }

            .option-btn:hover {
                background-color: #0066d1;
            }

            .option-btn i {
                color: #dfe9ff;
            }

        footer {
            text-align: center;
            font-size: 0.85rem;
            color: #6c757d;
            padding: 1rem 0;
            border-top: 1px solid #e3e9f0;
            background-color: #f9fbff;
            margin-top: auto;
            width: 100%;
        }
    </style>
}

<div class="main-container">

    <!-- Logo -->
    <div class="logo-container">
        <img src="~/images/ClinicaStaMonicaLogoP.png" alt="Logo Clínica Santa Monica">
    </div>

    <!-- Perfil -->
    <div class="profile-section">
        <img src="@(Model.Img_Perfil ?? "/images/default-user.jpg")" alt="Foto de perfil del usuario">

        <form asp-controller="Usuario" asp-action="Logout" method="post">
            <button type="submit" class="logout-btn">
                <i class="bi bi-box-arrow-right me-1"></i> Cerrar sesión
            </button>
        </form>
    </div>

    <!-- Bienvenida -->
    <div class="welcome">
        <h2>¡Hola, @Model.Nombres!</h2>
        <p>Cargo: @Model.Rol</p>
        <p class="friendly-msg">¿Qué deseas hacer hoy?</p>
    </div>

    <!-- Opción -->
    <div class="options">
        <div class="card-option">
            <i class="bi bi-receipt-cutoff"></i>
            <h4>Gestionar Comprobantes de Pago</h4>
            <p>Registra, consulta y administra los comprobantes de pago emitidos por los servicios médicos.</p>

            <a asp-controller="ComprobanteDePago" asp-action="Listar" class="btn option-btn">
                <i class="bi bi-arrow-right-circle"></i> Ingresar
            </a>
        </div>
    </div>

</div>

<footer>
    © 2026 Clínica Santa Mónica — Sistema de Gestión Hospitalaria
</footer>