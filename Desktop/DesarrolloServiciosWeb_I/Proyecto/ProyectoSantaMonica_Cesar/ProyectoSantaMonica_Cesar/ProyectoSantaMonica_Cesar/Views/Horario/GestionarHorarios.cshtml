@model ProyectoSantaMonica_Cesar.Models.Horario
@using ProyectoSantaMonica_Cesar.Models
@using ProyectoSantaMonica_Cesar.Models.enums

@{
    ViewData["Title"] = "Gestión de Horarios";
    var listaHorarios = ViewBag.ListaHorarios as List<Horario>;
    var medico = ViewBag.Medico as Medico;
    var listaMedicos = ViewBag.ListaMedicos as List<Medico>;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
        padding-bottom: 30px;
    }

    .header-bar {
        background-color: #007bff;
        color: white;
        border-radius: 12px;
        padding: 15px 25px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-form {
        background-color: #fff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        margin-bottom: 30px;
    }

    .btn-success {
        background-color: #28c76f;
    }

    .btn-info {
        background-color: #17a2b8;
        color: white;
    }

    .btn-danger {
        background-color: #e63946;
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="header-bar">
        <h3><i class="bi bi-calendar-check me-2"></i>Gestión de Horarios</h3>
    </div>

    <!-- DATOS MÉDICO -->
    <div class="card-form mt-4">
        <div class="row g-3">
            <div class="col-md-3">
                <label>DNI</label>
                <input value="@medico?.Dni" class="form-control" readonly />
            </div>
            <div class="col-md-3">
                <label>Nombres</label>
                <input value="@medico?.Nombres" class="form-control" readonly />
            </div>
            <div class="col-md-3">
                <label>Apellidos</label>
                <input value="@medico?.Apellidos" class="form-control" readonly />
            </div>
            <div class="col-md-3">
                <label>Especialidad</label>
                <input value="@medico?.Especialidad" class="form-control" readonly />
            </div>
        </div>
    </div>

    <!-- BOTÓN MODAL -->
    <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#modalMedico">
        <i class="bi bi-search"></i> Buscar Médico
    </button>

    <!-- MODAL -->
    <div class="modal fade" id="modalMedico">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5>Buscar Médico</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text" id="buscadorMedico" class="form-control mb-3" placeholder="Buscar..." />

                    <table class="table table-bordered text-center">
                        <thead>
                            <tr>
                                <th>Nombres</th>
                                <th>Apellidos</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody id="cuerpoMedicos">
                            @foreach (var m in listaMedicos)
                            {
                                <tr>
                                    <td>@m.Nombres</td>
                                    <td>@m.Apellidos</td>
                                    <td>
                                        <a href="@Url.Action("GestionarHorarios", new { idMedico = m.Id_Medico })"
                                           class="btn btn-success btn-sm">
                                            Seleccionar
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
            </div>
        </div>
    </div>

    <hr />

    <!-- TABLA HORARIOS -->
    <h5>Horarios Registrados</h5>
    <table class="table table-bordered text-center">
        <thead>
            <tr>
                <th>Día</th>
                <th>Entrada</th>
                <th>Salida</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            @if (listaHorarios != null && listaHorarios.Any())
            {
                foreach (var h in listaHorarios)
                {
                    <tr>
                        <td>@h.Dia_Semana</td>
                        <td>@h.Horario_Entrada</td>
                        <td>@h.Horario_Salida</td>
                        <td>
                            <a href="@Url.Action("Eliminar", new { id = h.Id_Horario, idMedico = medico?.Id_Medico })"
                               class="btn btn-danger btn-sm">
                                Eliminar
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4">No hay horarios</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- FORMULARIO -->
    <div class="card-form">
        <form asp-action="Registrar" method="post">

            <input type="hidden" asp-for="Id_Medico" value="@ViewBag.IdMedico" />

            <div class="row">
                <div class="col-md-3">
                    <label>Día</label>
                    <select asp-for="Dia_Semana" class="form-select"
                            asp-items="Html.GetEnumSelectList<DiaSemana>()">
                        <option value="">Seleccione</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label>Entrada</label>
                    <input type="time" asp-for="Horario_Entrada" class="form-control" step="60" />
                </div>

                <div class="col-md-3">
                    <label>Salida</label>
                    <input type="time" asp-for="Horario_Salida" class="form-control" step="60" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-success w-100">
                        Registrar
                    </button>
                </div>
            </div>
        </form>
    </div>

    <a href="@Url.Action("GestionarHorarios")" class="btn btn-secondary w-100">Limpiar</a>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire('Éxito', '@TempData["Success"]', 'success');
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire('Error', '@TempData["Error"]', 'error');
    </script>
}