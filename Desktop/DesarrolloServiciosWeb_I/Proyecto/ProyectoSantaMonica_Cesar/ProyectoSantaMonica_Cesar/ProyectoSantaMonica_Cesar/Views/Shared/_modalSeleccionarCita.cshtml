<!-- MODAL (colócalo SIEMPRE al final de la vista) -->
<div class="modal fade" id="buscarCitaModal" tabindex="-1" aria-labelledby="buscarCitaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content modal-custom">

            <div class="modal-header modal-header-custom">
                <h5 class="modal-title" id="buscarCitaLabel">
                    <i class="bi bi-search me-2"></i>Buscar Cita
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3 d-flex">
                    <input type="text"
                           id="textoCita"
                           class="form-control me-2 input-busqueda"
                           placeholder="Buscar por paciente o fecha">

                    <button type="button"
                            class="btn btn-buscar"
                            id="btnBuscarCitas">
                        <i class="bi bi-search"></i> Buscar
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-custom" id="tablaCitas">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Paciente</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Médico</th>
                                <th>Motivo</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- dinámico -->
                        </tbody>
                    </table>
                </div>

            </div>

        </div>
    </div>
</div>

<!-- ESTILOS (no cambia nada importante) -->
<style>
    .modal-custom {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    }

    .modal-header-custom {
        background-color: #007bff;
        color: white;
        font-weight: 600;
        padding: 15px 20px;
    }

        .modal-header-custom .btn-close {
            filter: invert(1);
        }

    .modal-body {
        padding: 20px;
        background-color: #f9fbff;
    }

    .input-busqueda {
        border-radius: 8px;
        height: 40px;
        font-size: 0.9rem;
    }

    .btn-buscar {
        background-color: #17a2b8;
        color: white;
        border: none;
        font-weight: 500;
        padding: 0 15px;
        border-radius: 8px;
        height: 40px;
        transition: all 0.2s ease;
    }

        .btn-buscar:hover {
            background-color: #138496;
            transform: translateY(-1px);
        }

    .table-custom {
        border-radius: 10px;
        overflow: hidden;
        font-size: 0.9rem;
        background-color: white;
    }

        .table-custom thead {
            background-color: #eaf2ff;
            color: #0056b3;
            font-weight: 600;
        }

        .table-custom tbody tr:nth-child(even) {
            background-color: #f8fbff;
        }

        .table-custom tbody tr:hover {
            background-color: #edf4ff;
            transition: 0.2s;
        }

    .btn-seleccionar {
        background-color: #28c76f;
        color: white;
        border: none;
        font-size: 0.85rem;
        padding: 5px 10px;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

        .btn-seleccionar:hover {
            background-color: #22b365;
            transform: translateY(-1px);
        }
</style>

@section Scripts {
    <script src="~/js/cdp.js"></script>


}