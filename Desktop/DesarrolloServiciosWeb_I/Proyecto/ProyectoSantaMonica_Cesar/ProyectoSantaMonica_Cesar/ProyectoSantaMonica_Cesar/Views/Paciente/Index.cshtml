@model IEnumerable<ProyectoSantaMonica_Cesar.Models.Paciente>

@{
    ViewData["Title"] = "Listado de Pacientes";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        background-color: #f4f7fb;
        font-family: 'Poppins', sans-serif;
    }

    .card {
        border-radius: 16px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        max-width: 1100px;
        margin: 50px auto;
    }

    .card-header {
        background-color: #007bff;
        color: white;
        padding: 20px 25px;
    }

    .btn-success {
        background-color: #28c76f;
    }

    .btn-edit {
        background-color: #5a9bd5;
        color: white;
    }

    .btn-danger {
        background-color: #e63946;
    }

    .table thead {
        background-color: #eaf2ff;
        color: #0056b3;
    }
</style>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-people-fill me-2"></i>Listado de Pacientes</h4>
        </div>

        <div class="card-body">

            <div class="text-end mb-3">
                <a asp-action="Create" class="btn btn-success">
                    <i class="bi bi-person-plus"></i> Nuevo Paciente
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered text-center align-middle">
                    <thead>
                        <tr>
                            <th>Numero</th>
                            <th>Nombres</th>
                            <th>Apellidos</th>
                            <th>DNI</th>
                            <th>Fecha Nacimiento</th>
                            <th>Teléfono</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-muted">No hay pacientes registrados.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>@p.Id_Paciente</td>
                                    <td>@p.Nombres</td>
                                    <td>@p.Apellidos</td>
                                    <td>@p.Dni</td>
                                    <td>@(p.Fecha_Nacimiento?.ToString("dd/MM/yyyy"))</td>
                                    <td>@p.Telefono</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@p.Id_Paciente" class="btn btn-edit btn-sm">
                                            <i class="bi bi-pencil-square"></i> Editar
                                        </a>

                                        <button class="btn btn-danger btn-sm" onclick="confirmarEliminacion(@p.Id_Paciente)">
                                            <i class="bi bi-trash3"></i> Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<script>
    let mensaje = '@TempData["mensaje"]';
    let error = '@TempData["error"]';

    if (mensaje) {
    Swal.fire({ icon:'success', title:'Éxito', text:mensaje, timer:2500, showConfirmButton:false });
    }

    if (error) {
    Swal.fire({ icon:'error', title:'Error', text:error, timer:2500, showConfirmButton:false });
    }

    function confirmarEliminacion(id) {
    Swal.fire({
    title:'¿Está seguro?',
    text:'El paciente será eliminado definitivamente.',
    icon:'warning',
    showCancelButton:true
    }).then((result)=>{
    if(result.isConfirmed){
    window.location.href='/Paciente/Delete/'+id;
    }
    });
    }
</script>